# Core Application
SECRET_KEY=change-me-to-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,api.caerabouquet.shop

# CORS (Frontend Origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# External Services
FRONTEND_URL=http://localhost:3000
ML_SERVICE_BASE_URL=http://127.0.0.1:8080
EMAIL_VERIFICATION_BASE_URL=http://127.0.0.1:8000/api/auth/verify-email/
PASSWORD_RESET_BASE_URL=http://localhost:3000/reset-password

# Logging
LOG_LEVEL=INFO

# Order Guardrails
MAX_ORDER_QUANTITY=50
MAX_ORDER_TOTAL_PRICE=50000000.00
ORDER_CREATE_RATE_LIMIT=10/hour

# Request/Upload Limits
DATA_UPLOAD_MAX_MEMORY_SIZE=1048576
FILE_UPLOAD_MAX_MEMORY_SIZE=1048576

# Email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=change-me
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com